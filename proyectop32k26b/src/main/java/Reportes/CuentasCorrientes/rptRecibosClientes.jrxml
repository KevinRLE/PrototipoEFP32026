	<style name="Detail" fontName="Arial" fontSize="12"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    cpc.Cpccodigo                    AS ID_DOCUMENTO,
    CONCAT('CPC-', cpc.Cpccodigo)    AS NO_RECIBO,
    c.Clinombre                      AS CLIENTE,
    c.Clinit                         AS NIT,
    c.Clitelefono                    AS TELEFONO,
    c.Clidireccion                   AS DIRECCION,
    cpc.Cpcfecha                     AS FECHA_EMISION,
    cpc.Cpcmonto                     AS MONTO_ORIGINAL,
    cpc.Cpcsaldo                     AS SALDO_PENDIENTE,
    (cpc.Cpcmonto - cpc.Cpcsaldo)    AS TOTAL_PAGADO,
    CASE 
        WHEN cpc.Cpcestado = 'P' THEN 'PENDIENTE'
        WHEN cpc.Cpcestado = 'C' THEN 'CANCELADO'
        ELSE cpc.Cpcestado
    END                              AS ESTADO,
    m.Mccfecha                       AS FECHA_MOVIMIENTO,
    m.Mccconcepto                    AS CONCEPTO,
    CASE WHEN m.Mcctipo = 'CARGO' THEN m.Mccmonto ELSE 0 END AS CARGO,
    CASE WHEN m.Mcctipo = 'ABONO' THEN ABS(m.Mccmonto) ELSE 0 END AS ABONO,
    m.Mccsaldo                       AS SALDO_ACUMULADO,
    t.TTnombretipo                   AS TIPO_TRANSACCION
FROM cuentasporcobrar cpc
JOIN clientes c ON c.Cliid = cpc.Cliid
LEFT JOIN movimientoscc m ON m.Cliid = cpc.Cliid
LEFT JOIN Cattipotransaccion t ON t.TTid = m.TTid
WHERE cpc.Cliid = 1
ORDER BY cpc.Cpcfecha ASC, m.Mccfecha ASC]]>
	</queryString>
