	<queryString language="SQL">
		<![CDATA[SELECT 
    m.Mccid,
    m.Mccfecha,
    m.Mccconcepto,
    m.Mccmodulo,
    m.Mcctipo,
    CASE WHEN m.Mcctipo = 'CARGO' THEN m.Mccmonto ELSE 0.00 END AS Cargo,
    CASE WHEN m.Mcctipo = 'ABONO' THEN ABS(m.Mccmonto) ELSE 0.00 END AS Abono,
    m.Mccmonto,
    m.Mccsaldo AS SaldoCorte,
    COALESCE(c.Clinombre, p.Pronombre) AS NombreEntidad
FROM movimientoscc m
LEFT JOIN clientes c ON m.Cliid = c.Cliid
LEFT JOIN proveedores p ON m.Procodigo = p.Procodigo
ORDER BY m.Mccfecha ASC, m.Mccid ASC;]]>
	</queryString>
