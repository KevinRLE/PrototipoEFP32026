	<field name="NO_RECIBO" class="java.lang.String"/>
	<field name="PROVEEDOR" class="java.lang.String"/>
	<field name="NIT" class="java.lang.String"/>
	<field name="CONTACTO" class="java.lang.String"/>
	<field name="DEPARTAMENTO" class="java.lang.String"/>
	<field name="FECHA_EMISION" class="java.sql.Date"/>
	<field name="MONTO_ORIGINAL" class="java.math.BigDecimal"/>
	<field name="SALDO_PENDIENTE" class="java.math.BigDecimal"/>
	<field name="TOTAL_PAGADO" class="java.math.BigDecimal"/>
	<field name="ESTADO" class="java.lang.String"/>
	<field name="TIPO_DEUDA" class="java.lang.String"/>
	<field name="FECHA_MOVIMIENTO" class="java.time.LocalDateTime"/>
	<field name="CONCEPTO" class="java.lang.String"/>
	<field name="CARGO" class="java.math.BigDecimal"/>
	<field name="ABONO" class="java.math.BigDecimal"/>
	<field name="SALDO_ACUMULADO" class="java.math.BigDecimal"/>
