	<queryString language="SQL">
		<![CDATA[-- Usa este query temporal en iReport si el asistente se traba:
SELECT 
    m.Mccid,
    m.Mccfecha,
    m.Mccmonto,
    m.Mccconcepto,
    m.Mccsaldo,
    m.Mccmodulo,
    m.Mcctipo,
    COALESCE(c.Clinombre, p.Pronombre) AS NombreEntidad
FROM movimientoscc m
LEFT JOIN clientes c ON m.Cliid = c.Cliid
LEFT JOIN proveedores p ON m.Procodigo = p.Procodigo
ORDER BY m.Mccfecha DESC;]]>
	</queryString>
